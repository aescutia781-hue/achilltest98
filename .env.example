# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=achilltest
POSTGRES_PASSWORD=cambia-esta-password-segura
POSTGRES_DB=achilltest
DATABASE_URL=postgres://achilltest:cambia-esta-password-segura@localhost:5432/achilltest

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Servidor ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── JWT ─────────────────────────────────────────────────────
# Genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-64-bytes-aleatorios-en-produccion

# ─── Encriptación de secretos del Crypto Vault (API Testing) ─
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: si cambias este valor en producción, todos los secretos guardados
# por usuarios para sus colecciones de API Testing se vuelven indescifrables.
SERVER_ENCRYPTION_KEY=cambia-esto-por-32-bytes-hex-en-produccion

# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Storage (artifacts) ─────────────────────────────────────
# En docker compose se usa /data/screenshots y /data/reports
# En local dev: /tmp/...
SCREENSHOT_DIR=/tmp/achilltest-screenshots
REPORTS_DIR=/tmp/achilltest-reports

# ─── Workers ─────────────────────────────────────────────────
# Concurrency por worker (cuántos jobs simultáneos maneja un worker)
WORKER_CONCURRENCY=3
# Total simultáneos = N_workers × WORKER_CONCURRENCY
# Default 8 workers × 3 = 24 simultáneos
# Para escalar: docker compose up -d --scale worker=20  (= 60 simultáneos)

# ─── Mercado Pago ────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-...
MP_CURRENCY=MXN
MP_PRICE_STARTER=1380     # $78.99 USD × $17.46 MXN
MP_PRICE_TEAMMATE=2252    # $128.99 USD × $17.46 MXN

# Los IDs se generan automáticamente al primer arranque.
MP_PLAN_STARTER_ID=
MP_PLAN_TEAMMATE_ID=

# ─── GitHub Integration ──────────────────────────────────────
# OAuth App: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://achilltest.io/api/github/oauth/callback

# ─── Jira + Zephyr Integration ───────────────────────────────
# OAuth 2.0 App de Atlassian: https://developer.atlassian.com/console/myapps/
# Scopes requeridos:
#   read:jira-user, read:jira-work, write:jira-work,
#   manage:jira-project, offline_access
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_OAUTH_REDIRECT_URI=https://achilltest.io/api/jira/oauth/callback

# ─── Frontend URL ────────────────────────────────────────────
# Usada para OAuth callbacks y share links de orgs invites
FRONTEND_URL=https://achilltest.io

# ─── Repair Agent (Anthropic Claude) ─────────────────────────
# API key del workspace Anthropic. Sin esto el Repair Agent devuelve 503.
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Email Transaccional (Resend) ────────────────────────────
# Obtener en: https://resend.com/api-keys
# Free tier: 3,000 emails/mes (100/día)
# Sin RESEND_API_KEY el sistema entra en modo DEV (loggea a consola).
RESEND_API_KEY=re_...

# From line de los emails enviados (debe ser un dominio verificado en Resend)
EMAIL_FROM=Achilltest <noreply@achilltest.io>

# Opcional: poner 'true' para desactivar todos los emails (testing/staging)
# EMAILS_DISABLED=false
